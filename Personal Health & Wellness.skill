    def _create_exercise_program(self) -> Dict:
        """Create personalized exercise program"""
        
        goal = self.profile.primary_goal
        
        if goal == Goal.MUSCLE_GAIN:
            program = self._strength_training_program()
        elif goal == Goal.WEIGHT_LOSS:
            program = self._fat_loss_program()
        elif goal == Goal.ATHLETIC_PERFORMANCE:
            program = self._performance_program()
        elif goal == Goal.LONGEVITY:
            program = self._longevity_program()
        else:
            program = self._general_fitness_program()
        
        return program
    
