        # Filter based on dietary restrictions
        return self._filter_by_restrictions(recommendations)
    
    def _create_sample_meal_plan(self, macros: Dict) -> Dict:
        """Create sample daily meal plan"""
        
        meal_plan = {
            'breakfast': {
                'meal': 'Protein Oatmeal Bowl',
                'ingredients': [
                    '80g oats',
