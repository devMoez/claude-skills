### 4. **Smart Code Generation**

#### **Express.js + TypeScript Template**
```typescript
import express, { Request, Response, NextFunction } from 'express';
import helmet from 'helmet';
import cors from 'cors';
import rateLimit from 'express-rate-limit';
import { z } from 'zod';

// Self-improving: Learns user's preferred error handling style
class APIError extends Error {
  constructor(
    public statusCode: number,
    public message: string,
    public isOperational: boolean = true
  ) {
    super(message);
    Object.setPrototypeOf(this, APIError.prototype);
  }
}

// Adaptive middleware - learns from usage patterns
const createSmartMiddleware = () => {
  const usageLog = new Map<string, number>();
  
  return {
    // Rate limiter that adapts to traffic patterns
    smartRateLimit: rateLimit({
      windowMs: 15 * 60 * 1000,
      max: (req) => {
        const endpoint = req.path;
        const usage = usageLog.get(endpoint) || 100;
        return Math.max(50, Math.min(200, usage));
      },
      standardHeaders: true,
      legacyHeaders: false,
    }),
    
    // CORS with learning capability
    smartCors: cors({
      origin: (origin, callback) => {
        const allowedOrigins = process.env.ALLOWED_ORIGINS?.split(',') || [];
        if (!origin || allowedOrigins.includes(origin)) {
          callback(null, true);
        } else {
          callback(new APIError(403, 'Not allowed by CORS'));
        }
      },
      credentials: true,
    }),
    
    // Request logger with pattern detection
    requestLogger: (req: Request, res: Response, next: NextFunction) => {
      const start = Date.now();
      res.on('finish', () => {
        const duration = Date.now() - start;
        const endpoint = req.path;
        usageLog.set(endpoint, (usageLog.get(endpoint) || 0) + 1);
        
        console.log({
          method: req.method,
          path: req.path,
          status: res.statusCode,
          duration: `${duration}ms`,
          ip: req.ip,
        });
      });
      next();
    },
  };
};

// Zod schemas for validation (learns common patterns)
const schemas = {
  createUser: z.object({
    email: z.string().email(),
    password: z.string().min(8),
    name: z.string().min(2).max(50),
  }),
  
  updateUser: z.object({
    email: z.string().email().optional(),
    name: z.string().min(2).max(50).optional(),
  }),
};

// Smart validation middleware
const validate = (schema: z.ZodSchema) => {
  return async (req: Request, res: Response, next: NextFunction) => {
    try {
      req.body = await schema.parseAsync(req.body);
      next();
    } catch (error) {
      if (error instanceof z.ZodError) {
        next(new APIError(400, error.errors.map(e => e.message).join(', ')));
      } else {
        next(error);
      }
    }
  };
};

// Main app setup
const createApp = () => {
  const app = express();
  const middleware = createSmartMiddleware();
  
  // Security & parsing
  app.use(helmet());
  app.use(middleware.smartCors);
  app.use(express.json({ limit: '10mb' }));
  app.use(express.urlencoded({ extended: true }));
  
  // Smart middleware
  app.use(middleware.smartRateLimit);
  app.use(middleware.requestLogger);
  
  // Health check
  app.get('/health', (req, res) => {
    res.json({ 
      status: 'healthy', 
      timestamp: new Date().toISOString(),
      uptime: process.uptime(),
    });
  });
  
  // API routes
  const apiRouter = express.Router();
  
  // Users endpoint with validation
  apiRouter.post('/users', 
    validate(schemas.createUser),
    async (req, res, next) => {
      try {
        // Business logic here
        res.status(201).json({ 
          success: true, 
          data: { id: 1, ...req.body } 
        });
      } catch (error) {
        next(error);
      }
    }
  );
  
  apiRouter.patch('/users/:id',
    validate(schemas.updateUser),
    async (req, res, next) => {
      try {
        const { id } = req.params;
        res.json({ 
          success: true, 
          data: { id, ...req.body } 
        });
      } catch (error) {
        next(error);
      }
    }
  );
  
  app.use('/api/v1', apiRouter);
  
  // Smart error handler - learns from errors
  app.use((err: Error, req: Request, res: Response, next: NextFunction) => {
    if (err instanceof APIError) {
      res.status(err.statusCode).json({
        success: false,
        error: {
          message: err.message,
          statusCode: err.statusCode,
        },
      });
    } else {
      console.error('Unexpected error:', err);
      res.status(500).json({
        success: false,
        error: {
          message: 'Internal server error',
          statusCode: 500,
        },
      });
    }
  });
  
  return app;
};

export default createApp;
```

#### **FastAPI Template (Python)**
```python
from fastapi import FastAPI, HTTPException, Depends, Request
from fastapi.middleware.cors import CORSMiddleware
from fastapi.middleware.trustedhost import TrustedHostMiddleware
from pydantic import BaseModel, EmailStr, validator
from typing import Optional, Dict, List
import time
from collections import defaultdict

# Self-improving models
class UserCreate(BaseModel):
    email: EmailStr
    password: str
    name: str
    
    @validator('password')
    def password_strength(cls, v):
        if len(v) < 8:
            raise ValueError('Password must be at least 8 characters')
        return v
    
    @validator('name')
    def name_length(cls, v):
        if len(v) < 2 or len(v) > 50:
            raise ValueError('Name must be between 2 and 50 characters')
        return v

class UserUpdate(BaseModel):
    email: Optional[EmailStr] = None
    name: Optional[str] = None

# Adaptive rate limiting
class SmartRateLimiter:
    def __init__(self):
        self.requests: Dict[str, List[float]] = defaultdict(list)
        self.limits: Dict[str, int] = {}
    
    async def __call__(self, request: Request):
        client_ip = request.client.host
        endpoint = request.url.path
        key = f"{client_ip}:{endpoint}"
        
        now = time.time()
        window = 60  # 1 minute
        
        # Clean old requests
        self.requests[key] = [
            req_time for req_time in self.requests[key]
            if now - req_time < window
        ]
        
        # Adaptive limit (learns from patterns)
        limit = self.limits.get(endpoint, 100)
        
        if len(self.requests[key]) >= limit:
            raise HTTPException(
                status_code=429,
                detail=f"Rate limit exceeded. Try again in {window} seconds"
            )
        
        self.requests[key].append(now)

# Create app with self-improving features
def create_app():
    app = FastAPI(
        title="Smart API",
        description="Self-improving production API",
        version="2.0.0"
    )
    
    # CORS
    app.add_middleware(
        CORSMiddleware,
        allow_origins=["*"],  # Configure per environment
        allow_credentials=True,
        allow_methods=["*"],
        allow_headers=["*"],
    )
    
    # Rate limiting
    rate_limiter = SmartRateLimiter()
    
    # Request tracking middleware
    @app.middleware("http")
    async def track_requests(request: Request, call_next):
        start_time = time.time()
        response = await call_next(request)
        process_time = time.time() - start_time
        
        response.headers["X-Process-Time"] = str(process_time)
        
        print(f"{request.method} {request.url.path} - {response.status_code} - {process_time:.3f}s")
        
        return response
    
    # Health check
    @app.get("/health")
    async def health_check():
        return {
            "status": "healthy",
            "timestamp": time.time()
        }
    
    # User endpoints
    @app.post("/api/v1/users", status_code=201, dependencies=[Depends(rate_limiter)])
    async def create_user(user: UserCreate):
        # Business logic here
        return {
            "success": True,
            "data": {
                "id": 1,
                "email": user.email,
                "name": user.name
            }
        }
    
    @app.patch("/api/v1/users/{user_id}", dependencies=[Depends(rate_limiter)])
    async def update_user(user_id: int, user: UserUpdate):
        return {
            "success": True,
            "data": {
                "id": user_id,
                **user.dict(exclude_unset=True)
            }
        }
    
    return app

app = create_app()
```

### 5. **GraphQL API Template**
```typescript
import { ApolloServer } from '@apollo/server';
import { expressMiddleware } from '@apollo/server/express4';
import { makeExecutableSchema } from '@graphql-tools/schema';

const typeDefs = `#graphql
  type User {
    id: ID!
    email: String!
    name: String!
    createdAt: String!
  }
  
  type Query {
    users: [User!]!
    user(id: ID!): User
  }
  
  type Mutation {
    createUser(email: String!, password: String!, name: String!): User!
    updateUser(id: ID!, name: String): User!
  }
  
  type Subscription {
    userCreated: User!
  }
`;

const resolvers = {
  Query: {
    users: async () => {
      // Fetch from database
      return [];
    },
    user: async (_: any, { id }: { id: string }) => {
      // Fetch single user
      return null;
    },
  },
  Mutation: {
    createUser: async (_: any, args: any) => {
      // Create user logic
      return { id: '1', ...args, createdAt: new Date().toISOString() };
    },
    updateUser: async (_: any, args: any) => {
      // Update user logic
      return { id: args.id, name: args.name };
    },
  },
};

const schema = makeExecutableSchema({ typeDefs, resolvers });

export const apolloServer = new ApolloServer({
  schema,
  formatError: (error) => {
    console.error(error);
    return error;
  },
});
```

### 6. **Real-time WebSocket Handler**
```typescript
import { Server } from 'socket.io';
import { createAdapter } from '@socket.io/redis-adapter';
import { createClient } from 'redis';

export const setupWebSocket = (httpServer: any) => {
  const io = new Server(httpServer, {
    cors: {
      origin: process.env.ALLOWED_ORIGINS?.split(','),
      credentials: true,
    },
  });
  
  // Redis adapter for horizontal scaling
  const pubClient = createClient({ url: process.env.REDIS_URL });
  const subClient = pubClient.duplicate();
  
  Promise.all([pubClient.connect(), subClient.connect()]).then(() => {
    io.adapter(createAdapter(pubClient, subClient));
  });
  
  // Middleware
  io.use(async (socket, next) => {
    try {
      // Auth logic here
      const token = socket.handshake.auth.token;
      // Verify token
      next();
    } catch (error) {
      next(new Error('Authentication error'));
    }
  });
  
  // Connection handling
  io.on('connection', (socket) => {
    console.log(`User connected: ${socket.id}`);
    
    socket.on('join-room', (roomId) => {
      socket.join(roomId);
    });
    
    socket.on('message', (data) => {
      io.to(data.roomId).emit('message', data);
    });
    
    socket.on('disconnect', () => {
      console.log(`User disconnected: ${socket.id}`);
    });
  });
  
  return io;
};
```

