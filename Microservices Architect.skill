# Microservices Architect Skill
**Version:** 2.0.0  
**Type:** Self-Improving | Distributed Systems | Service Orchestration

## Core Purpose
Design and implement scalable microservices architectures with intelligent service communication, distributed tracing, circuit breakers, and event-driven patterns.

## Self-Improvement Engine
```yaml
learning_capabilities:
  - Track service communication patterns
  - Learn optimal service boundaries
  - Adapt retry and timeout strategies
  - Monitor service health trends
  - Optimize inter-service dependencies
```

## Architecture Patterns

### Service Communication
- **REST APIs** (HTTP/JSON)
- **gRPC** (Protocol Buffers)
- **Message Queues** (RabbitMQ, Kafka)
- **Event Streaming** (Apache Kafka, NATS)
- **Service Mesh** (Istio, Linkerd)

### Core Principles
- Single Responsibility per Service
- Database per Service
- API Gateway Pattern
- Circuit Breaker Pattern
- Event-Driven Architecture
- SAGA Pattern for Distributed Transactions

## Smart Service Template

### **Node.js Microservice with TypeScript**
```typescript
import express, { Request, Response, NextFunction } from 'express';
import { createClient } from 'redis';
import { Kafka, Producer, Consumer } from 'kafkajs';
import { Tracer } from '@opentelemetry/api';
import CircuitBreaker from 'opossum';

// Service configuration with self-optimization
interface ServiceConfig {
  name: string;
  version: string;
  port: number;
  dependencies: string[];
  healthCheck: {
    interval: number;
    timeout: number;
  };
}

const config: ServiceConfig = {
  name: 'user-service',
  version: '1.0.0',
  port: 3001,
  dependencies: ['auth-service', 'notification-service'],
  healthCheck: {
    interval: 30000,
    timeout: 5000,
  },
};

// Smart circuit breaker with adaptive thresholds
class AdaptiveCircuitBreaker {
  private breakers = new Map<string, CircuitBreaker>();
  private successRates = new Map<string, number[]>();
  
  getBreaker(serviceName: string, action: () => Promise<any>) {
    if (this.breakers.has(serviceName)) {
      return this.breakers.get(serviceName)!;
    }
    
    const options = {
      timeout: 3000,
      errorThresholdPercentage: 50,
      resetTimeout: 30000,
      rollingCountTimeout: 10000,
      rollingCountBuckets: 10,
    };
    
    const breaker = new CircuitBreaker(action, options);
    
    // Learn from patterns
    breaker.on('success', () => {
      this.trackSuccess(serviceName, true);
    });
    
    breaker.on('failure', () => {
      this.trackSuccess(serviceName, false);
    });
    
    breaker.on('open', () => {
      console.warn(`Circuit breaker opened for ${serviceName}`);
    });
    
    this.breakers.set(serviceName, breaker);
    return breaker;
  }
  
  private trackSuccess(serviceName: string, success: boolean) {
    const rates = this.successRates.get(serviceName) || [];
    rates.push(success ? 1 : 0);
    
    if (rates.length > 100) {
      rates.shift();
    }
    
    this.successRates.set(serviceName, rates);
    
    // Adapt thresholds based on patterns
    const successRate = rates.reduce((a, b) => a + b, 0) / rates.length;
    const breaker = this.breakers.get(serviceName);
    
    if (breaker && successRate < 0.5) {
      console.log(`Adjusting circuit breaker for ${serviceName}, success rate: ${successRate}`);
    }
  }
}

// Service registry with health checking
class ServiceRegistry {
  private services = new Map<string, {
    url: string;
    healthy: boolean;
    lastCheck: Date;
  }>();
  
  private redis = createClient({
    url: process.env.REDIS_URL || 'redis://localhost:6379',
  });
  
  async init() {
    await this.redis.connect();
    await this.registerService();
    this.startHealthChecks();
  }
  
  async registerService() {
    const serviceInfo = {
      name: config.name,
      version: config.version,
      url: `http://localhost:${config.port}`,
      registeredAt: new Date().toISOString(),
    };
    
    await this.redis.set(
      `service:${config.name}`,
      JSON.stringify(serviceInfo),
      { EX: 60 } // Expire after 60 seconds
    );
    
    // Heartbeat every 30 seconds
    setInterval(() => this.registerService(), 30000);
  }
  
  async discoverService(serviceName: string): Promise<string | null> {
    const cached = this.services.get(serviceName);
    if (cached && cached.healthy) {
      return cached.url;
    }
    
    const serviceData = await this.redis.get(`service:${serviceName}`);
    if (!serviceData) return null;
    
    const service = JSON.parse(serviceData);
    this.services.set(serviceName, {
      url: service.url,
      healthy: true,
      lastCheck: new Date(),
    });
    
    return service.url;
  }
  
  private startHealthChecks() {
    setInterval(async () => {
      for (const [name, service] of this.services) {
        try {
          const response = await fetch(`${service.url}/health`, {
            signal: AbortSignal.timeout(config.healthCheck.timeout),
          });
          
          service.healthy = response.ok;
          service.lastCheck = new Date();
        } catch (error) {
          service.healthy = false;
          console.error(`Health check failed for ${name}:`, error);
        }
      }
    }, config.healthCheck.interval);
  }
}

// Event bus with Kafka
class EventBus {
  private kafka: Kafka;
  private producer: Producer;
  private consumers = new Map<string, Consumer>();
  
  constructor() {
    this.kafka = new Kafka({
      clientId: config.name,
      brokers: process.env.KAFKA_BROKERS?.split(',') || ['localhost:9092'],
    });
    
    this.producer = this.kafka.producer();
  }
  
  async init() {
    await this.producer.connect();
  }
  
  async publish(topic: string, event: any) {
    await this.producer.send({
      topic,
      messages: [{
        key: event.id || Date.now().toString(),
        value: JSON.stringify(event),
        timestamp: Date.now().toString(),
      }],
    });
    
    console.log(`Published event to ${topic}:`, event);
  }
  
  async subscribe(topic: string, handler: (event: any) => Promise<void>) {
    const consumer = this.kafka.consumer({
      groupId: `${config.name}-${topic}`,
    });
    
    await consumer.connect();
    await consumer.subscribe({ topic, fromBeginning: false });
    
    await consumer.run({
      eachMessage: async ({ topic, partition, message }) => {
        try {
          const event = JSON.parse(message.value?.toString() || '{}');
          await handler(event);
        } catch (error) {
          console.error(`Error processing event from ${topic}:`, error);
          // Implement dead letter queue here
        }
      },
    });
    
    this.consumers.set(topic, consumer);
  }
  
  async close() {
    await this.producer.disconnect();
    for (const consumer of this.consumers.values()) {
      await consumer.disconnect();
    }
  }
}

// Service-to-service communication
class ServiceClient {
  private circuitBreaker = new AdaptiveCircuitBreaker();
  private registry: ServiceRegistry;
  
  constructor(registry: ServiceRegistry) {
    this.registry = registry;
  }
  
  async call<T>(
    serviceName: string,
    endpoint: string,
    options: RequestInit = {}
  ): Promise<T> {
    const serviceUrl = await this.registry.discoverService(serviceName);
    if (!serviceUrl) {
      throw new Error(`Service ${serviceName} not found`);
    }
    
    const breaker = this.circuitBreaker.getBreaker(
      serviceName,
      async () => {
        const response = await fetch(`${serviceUrl}${endpoint}`, {
          ...options,
          headers: {
            'Content-Type': 'application/json',
            'X-Request-ID': this.generateRequestId(),
            'X-Service-Name': config.name,
            ...options.headers,
          },
        });
        
        if (!response.ok) {
          throw new Error(`Service call failed: ${response.statusText}`);
        }
        
        return response.json();
      }
    );
    
    return breaker.fire();
  }
  
  private generateRequestId(): string {
    return `${config.name}-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
  }
}

// SAGA orchestrator for distributed transactions
class SagaOrchestrator {
  private steps: Array<{
    execute: () => Promise<any>;
    compensate: () => Promise<void>;
  }> = [];
  
  private executed: number[] = [];
  
  addStep(
    execute: () => Promise<any>,
    compensate: () => Promise<void>
  ) {
    this.steps.push({ execute, compensate });
    return this;
  }
  
  async run() {
    try {
      for (let i = 0; i < this.steps.length; i++) {
        const result = await this.steps[i].execute();
        this.executed.push(i);
        console.log(`SAGA step ${i} completed`);
      }
      
      return { success: true };
    } catch (error) {
      console.error('SAGA failed, compensating...', error);
      await this.compensate();
      throw error;
    }
  }
  
  private async compensate() {
    for (let i = this.executed.length - 1; i >= 0; i--) {
      const stepIndex = this.executed[i];
      try {
        await this.steps[stepIndex].compensate();
        console.log(`SAGA compensation ${stepIndex} completed`);
      } catch (error) {
        console.error(`SAGA compensation ${stepIndex} failed:`, error);
      }
    }
  }
}

// Main service application
class MicroserviceApp {
  private app = express();
  private registry = new ServiceRegistry();
  private eventBus = new EventBus();
  private serviceClient!: ServiceClient;
  
  async init() {
    // Middleware
    this.app.use(express.json());
    this.app.use(this.requestTracking);
    
    // Initialize dependencies
    await this.registry.init();
    await this.eventBus.init();
    this.serviceClient = new ServiceClient(this.registry);
    
    // Setup routes
    this.setupRoutes();
    
    // Subscribe to events
    await this.subscribeToEvents();
    
    // Graceful shutdown
    this.setupGracefulShutdown();
  }
  
  private requestTracking(req: Request, res: Response, next: NextFunction) {
    const requestId = req.headers['x-request-id'] || Date.now().toString();
    req.headers['x-request-id'] = requestId as string;
    
    const start = Date.now();
    res.on('finish', () => {
      const duration = Date.now() - start;
      console.log({
        requestId,
        method: req.method,
        path: req.path,
        status: res.statusCode,
        duration: `${duration}ms`,
      });
    });
    
    next();
  }
  
  private setupRoutes() {
    // Health check
    this.app.get('/health', (req, res) => {
      res.json({
        service: config.name,
        version: config.version,
        status: 'healthy',
        uptime: process.uptime(),
        timestamp: new Date().toISOString(),
      });
    });
    
    // Readiness check
    this.app.get('/ready', async (req, res) => {
      const dependencies = await Promise.all(
        config.dependencies.map(async (dep) => {
          const url = await this.registry.discoverService(dep);
          return { service: dep, available: !!url };
        })
      );
      
      const ready = dependencies.every(d => d.available);
      
      res.status(ready ? 200 : 503).json({
        ready,
        dependencies,
      });
    });
    
    // Business logic routes
    this.app.post('/api/users', async (req, res, next) => {
      try {
        // Call auth service
        const authResult = await this.serviceClient.call(
          'auth-service',
          '/api/validate',
          {
            method: 'POST',
            body: JSON.stringify({ token: req.headers.authorization }),
          }
        );
        
        // Business logic here
        const user = { id: 1, ...req.body };
        
        // Publish event
        await this.eventBus.publish('user.created', {
          id: user.id,
          timestamp: new Date().toISOString(),
        });
        
        res.status(201).json({ success: true, data: user });
      } catch (error) {
        next(error);
      }
    });
    
    // SAGA example
    this.app.post('/api/orders', async (req, res, next) => {
      try {
        const saga = new SagaOrchestrator()
          .addStep(
            async () => {
              // Reserve inventory
              return this.serviceClient.call(
                'inventory-service',
                '/api/reserve',
                {
                  method: 'POST',
                  body: JSON.stringify(req.body.items),
                }
              );
            },
            async () => {
              // Release inventory
              await this.serviceClient.call(
                'inventory-service',
                '/api/release',
                { method: 'POST' }
              );
            }
          )
          .addStep(
            async () => {
              // Process payment
              return this.serviceClient.call(
                'payment-service',
                '/api/charge',
                {
                  method: 'POST',
                  body: JSON.stringify(req.body.payment),
                }
              );
            },
            async () => {
              // Refund payment
              await this.serviceClient.call(
                'payment-service',
                '/api/refund',
                { method: 'POST' }
              );
            }
          )
          .addStep(
            async () => {
              // Create order
              return this.serviceClient.call(
                'order-service',
                '/api/create',
                {
                  method: 'POST',
                  body: JSON.stringify(req.body),
                }
              );
            },
            async () => {
              // Cancel order
              await this.serviceClient.call(
                'order-service',
                '/api/cancel',
                { method: 'POST' }
              );
            }
          );
        
        const result = await saga.run();
        res.status(201).json(result);
      } catch (error) {
        next(error);
      }
    });
    
    // Error handler
    this.app.use((err: Error, req: Request, res: Response, next: NextFunction) => {
      console.error('Error:', err);
      res.status(500).json({
        success: false,
        error: {
          message: err.message,
          service: config.name,
        },
      });
    });
  }
  
  private async subscribeToEvents() {
    await this.eventBus.subscribe('user.created', async (event) => {
      console.log('Received user.created event:', event);
      // Handle event
    });
  }
  
  private setupGracefulShutdown() {
    const shutdown = async (signal: string) => {
      console.log(`${signal} received, shutting down gracefully...`);
      
      await this.eventBus.close();
      
      process.exit(0);
    };
    
    process.on('SIGTERM', () => shutdown('SIGTERM'));
    process.on('SIGINT', () => shutdown('SIGINT'));
  }
  
  start() {
    this.app.listen(config.port, () => {
      console.log(`${config.name} v${config.version} listening on port ${config.port}`);
    });
  }
}

// Start the service
const service = new MicroserviceApp();
service.init().then(() => service.start());
```

## Docker & Kubernetes Deployment

### **Dockerfile**
```dockerfile
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY . .
RUN npm run build

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY package.json ./

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3001/health', (r) => process.exit(r.statusCode === 200 ? 0 : 1))"

EXPOSE 3001
CMD ["node", "dist/server.js"]
```

### **Kubernetes Deployment**
```yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: user-service
  labels:
    app: user-service
spec:
  replicas: 3
  selector:
    matchLabels:
      app: user-service
  template:
    metadata:
      labels:
        app: user-service
        version: v1
    spec:
      containers:
      - name: user-service
        image: user-service:1.0.0
        ports:
        - containerPort: 3001
        env:
        - name: NODE_ENV
          value: production
        - name: REDIS_URL
          valueFrom:
            secretKeyRef:
              name: redis-secret
              key: url
        - name: KAFKA_BROKERS
          value: kafka:9092
        resources:
          requests:
            memory: "256Mi"
            cpu: "250m"
          limits:
            memory: "512Mi"
            cpu: "500m"
        livenessProbe:
          httpGet:
            path: /health
            port: 3001
          initialDelaySeconds: 30
          periodSeconds: 10
        readinessProbe:
          httpGet:
            path: /ready
            port: 3001
          initialDelaySeconds: 15
          periodSeconds: 5
---
apiVersion: v1
kind: Service
metadata:
  name: user-service
spec:
  selector:
    app: user-service
  ports:
  - port: 80
    targetPort: 3001
  type: ClusterIP
---
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: user-service-hpa
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: user-service
  minReplicas: 3
  maxReplicas: 10
  metrics:
  - type: Resource
    resource:
      name: cpu
      target:
        type: Utilization
        averageUtilization: 70
  - type: Resource
    resource:
      name: memory
      target:
        type: Utilization
        averageUtilization: 80
```

## Distributed Tracing

### **OpenTelemetry Integration**
```typescript
import { NodeTracerProvider } from '@opentelemetry/sdk-trace-node';
import { Resource } from '@opentelemetry/resources';
import { SemanticResourceAttributes } from '@opentelemetry/semantic-conventions';
import { JaegerExporter } from '@opentelemetry/exporter-jaeger';
import { BatchSpanProcessor } from '@opentelemetry/sdk-trace-base';

export function setupTracing() {
  const provider = new NodeTracerProvider({
    resource: new Resource({
      [SemanticResourceAttributes.SERVICE_NAME]: config.name,
      [SemanticResourceAttributes.SERVICE_VERSION]: config.version,
    }),
  });
  
  const exporter = new JaegerExporter({
    endpoint: process.env.JAEGER_ENDPOINT || 'http://localhost:14268/api/traces',
  });
  
  provider.addSpanProcessor(new BatchSpanProcessor(exporter));
  provider.register();
  
  return provider.getTracer(config.name);
}
```

