## Smart Contract Development

### **Solidity Smart Contracts**
```solidity
// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Burnable.sol";
import "@openzeppelin/contracts/security/Pausable.sol";
import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";

/**
 * @title AdvancedToken
 * @dev Feature-rich ERC20 token with role-based access control
 */
contract AdvancedToken is ERC20, ERC20Burnable, Pausable, AccessControl, ReentrancyGuard {
    bytes32 public constant MINTER_ROLE = keccak256("MINTER_ROLE");
    bytes32 public constant PAUSER_ROLE = keccak256("PAUSER_ROLE");
    
    uint256 public constant MAX_SUPPLY = 1_000_000_000 * 10**18; // 1 billion tokens
    
    mapping(address => bool) public blacklisted;
    mapping(address => uint256) public lockedBalances;
    mapping(address => uint256) public unlockTime;
    
    event TokensLocked(address indexed account, uint256 amount, uint256 unlockTime);
    event TokensUnlocked(address indexed account, uint256 amount);
    event AddressBlacklisted(address indexed account);
    event AddressWhitelisted(address indexed account);
    
    modifier notBlacklisted(address account) {
        require(!blacklisted[account], "Address is blacklisted");
        _;
    }
    
    constructor(string memory name, string memory symbol) ERC20(name, symbol) {
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _grantRole(MINTER_ROLE, msg.sender);
        _grantRole(PAUSER_ROLE, msg.sender);
    }
    
    /**
     * @dev Mint new tokens
     * @param to Address to receive tokens
     * @param amount Amount to mint
     */
    function mint(address to, uint256 amount) 
        external 
        onlyRole(MINTER_ROLE) 
        notBlacklisted(to) 
    {
        require(totalSupply() + amount <= MAX_SUPPLY, "Exceeds max supply");
        _mint(to, amount);
    }
    
    /**
     * @dev Lock tokens for a period
     * @param amount Amount to lock
     * @param duration Lock duration in seconds
     */
    function lockTokens(uint256 amount, uint256 duration) external nonReentrant {
        require(amount > 0, "Amount must be greater than 0");
        require(balanceOf(msg.sender) >= amount, "Insufficient balance");
        require(duration > 0, "Duration must be greater than 0");
        
        lockedBalances[msg.sender] += amount;
        unlockTime[msg.sender] = block.timestamp + duration;
        
        emit TokensLocked(msg.sender, amount, unlockTime[msg.sender]);
    }
    
    /**
     * @dev Unlock tokens after lock period
     */
    function unlockTokens() external nonReentrant {
        uint256 locked = lockedBalances[msg.sender];
        require(locked > 0, "No locked tokens");
        require(block.timestamp >= unlockTime[msg.sender], "Tokens still locked");
        
        lockedBalances[msg.sender] = 0;
        unlockTime[msg.sender] = 0;
        
        emit TokensUnlocked(msg.sender, locked);
    }
    
    /**
     * @dev Blacklist address
     * @param account Address to blacklist
     */
    function blacklistAddress(address account) external onlyRole(DEFAULT_ADMIN_ROLE) {
        blacklisted[account] = true;
        emit AddressBlacklisted(account);
    }
    
    /**
     * @dev Whitelist address
     * @param account Address to whitelist
     */
    function whitelistAddress(address account) external onlyRole(DEFAULT_ADMIN_ROLE) {
        blacklisted[account] = false;
        emit AddressWhitelisted(account);
    }
    
    /**
     * @dev Pause token transfers
     */
    function pause() external onlyRole(PAUSER_ROLE) {
        _pause();
    }
    
    /**
     * @dev Unpause token transfers
     */
    function unpause() external onlyRole(PAUSER_ROLE) {
        _unpause();
    }
    
    /**
     * @dev Get available balance (total - locked)
     * @param account Address to check
     */
    function availableBalance(address account) public view returns (uint256) {
        uint256 total = balanceOf(account);
        uint256 locked = lockedBalances[account];
        
        if (block.timestamp < unlockTime[account]) {
            return total > locked ? total - locked : 0;
        }
        
        return total;
    }
    
    /**
     * @dev Override transfer to include checks
     */
    function transfer(address to, uint256 amount) 
        public 
        virtual 
        override 
        whenNotPaused 
        notBlacklisted(msg.sender) 
        notBlacklisted(to) 
        returns (bool) 
    {
        require(availableBalance(msg.sender) >= amount, "Insufficient available balance");
        return super.transfer(to, amount);
    }
    
    /**
     * @dev Override transferFrom to include checks
     */
    function transferFrom(address from, address to, uint256 amount)
        public
        virtual
        override
        whenNotPaused
        notBlacklisted(from)
        notBlacklisted(to)
        returns (bool)
    {
        require(availableBalance(from) >= amount, "Insufficient available balance");
        return super.transferFrom(from, to, amount);
    }
}

/**
 * @title DeFiStakingPool
 * @dev Staking pool with rewards distribution
 */
contract DeFiStakingPool is ReentrancyGuard, Pausable, AccessControl {
    IERC20 public stakingToken;
    IERC20 public rewardToken;
    
    bytes32 public constant ADMIN_ROLE = keccak256("ADMIN_ROLE");
    
    uint256 public rewardRate = 100; // Reward per block per token staked
    uint256 public lastUpdateBlock;
    uint256 public rewardPerTokenStored;
    uint256 public totalStaked;
    
    mapping(address => uint256) public stakedBalance;
    mapping(address => uint256) public userRewardPerTokenPaid;
    mapping(address => uint256) public rewards;
    mapping(address => uint256) public stakingTime;
    
    event Staked(address indexed user, uint256 amount);
    event Withdrawn(address indexed user, uint256 amount);
    event RewardPaid(address indexed user, uint256 reward);
    event RewardRateUpdated(uint256 newRate);
    
    constructor(address _stakingToken, address _rewardToken) {
        stakingToken = IERC20(_stakingToken);
        rewardToken = IERC20(_rewardToken);
        
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _grantRole(ADMIN_ROLE, msg.sender);
        
        lastUpdateBlock = block.number;
    }
    
    modifier updateReward(address account) {
        rewardPerTokenStored = rewardPerToken();
        lastUpdateBlock = block.number;
        
        if (account != address(0)) {
            rewards[account] = earned(account);
            userRewardPerTokenPaid[account] = rewardPerTokenStored;
        }
        _;
    }
    
    /**
     * @dev Calculate reward per token
     */
    function rewardPerToken() public view returns (uint256) {
        if (totalStaked == 0) {
            return rewardPerTokenStored;
        }
        
        uint256 blocksPassed = block.number - lastUpdateBlock;
        uint256 rewardIncrease = blocksPassed * rewardRate * 1e18 / totalStaked;
        
        return rewardPerTokenStored + rewardIncrease;
    }
    
    /**
     * @dev Calculate earned rewards for account
     */
    function earned(address account) public view returns (uint256) {
        uint256 staked = stakedBalance[account];
        uint256 rewardDiff = rewardPerToken() - userRewardPerTokenPaid[account];
        uint256 newReward = staked * rewardDiff / 1e18;
        
        return rewards[account] + newReward;
    }
    
    /**
     * @dev Stake tokens
     */
    function stake(uint256 amount) external nonReentrant whenNotPaused updateReward(msg.sender) {
        require(amount > 0, "Cannot stake 0");
        
        totalStaked += amount;
        stakedBalance[msg.sender] += amount;
        stakingTime[msg.sender] = block.timestamp;
        
        require(stakingToken.transferFrom(msg.sender, address(this), amount), "Transfer failed");
        
        emit Staked(msg.sender, amount);
    }
    
    /**
     * @dev Withdraw staked tokens
     */
    function withdraw(uint256 amount) external nonReentrant updateReward(msg.sender) {
        require(amount > 0, "Cannot withdraw 0");
        require(stakedBalance[msg.sender] >= amount, "Insufficient balance");
        
        totalStaked -= amount;
        stakedBalance[msg.sender] -= amount;
        
        require(stakingToken.transfer(msg.sender, amount), "Transfer failed");
        
        emit Withdrawn(msg.sender, amount);
    }
    
    /**
     * @dev Claim rewards
     */
    function claimReward() external nonReentrant updateReward(msg.sender) {
        uint256 reward = rewards[msg.sender];
        require(reward > 0, "No rewards");
        
        rewards[msg.sender] = 0;
        require(rewardToken.transfer(msg.sender, reward), "Reward transfer failed");
        
        emit RewardPaid(msg.sender, reward);
    }
    
    /**
     * @dev Exit - withdraw all and claim rewards
     */
    function exit() external {
        withdraw(stakedBalance[msg.sender]);
        claimReward();
    }
    
    /**
     * @dev Update reward rate
     */
    function setRewardRate(uint256 _rewardRate) external onlyRole(ADMIN_ROLE) updateReward(address(0)) {
        rewardRate = _rewardRate;
        emit RewardRateUpdated(_rewardRate);
    }
    
    /**
     * @dev Pause staking
     */
    function pause() external onlyRole(ADMIN_ROLE) {
        _pause();
    }
    
    /**
     * @dev Unpause staking
     */
    function unpause() external onlyRole(ADMIN_ROLE) {
        _unpause();
    }
}

/**
 * @title NFTMarketplace
 * @dev Decentralized NFT marketplace with royalties
 */
contract NFTMarketplace is ReentrancyGuard, Pausable {
    struct Listing {
        address seller;
        address nftContract;
        uint256 tokenId;
        uint256 price;
        bool active;
    }
    
    struct Offer {
        address buyer;
        uint256 price;
        uint256 expiration;
        bool active;
    }
    
    mapping(bytes32 => Listing) public listings;
    mapping(bytes32 => Offer[]) public offers;
    mapping(address => mapping(uint256 => uint256)) public royalties; // NFT contract => token => royalty %
    
    uint256 public platformFee = 250; // 2.5%
    uint256 public constant FEE_DENOMINATOR = 10000;
    
    event Listed(bytes32 indexed listingId, address seller, address nftContract, uint256 tokenId, uint256 price);
    event Sold(bytes32 indexed listingId, address buyer, uint256 price);
    event ListingCancelled(bytes32 indexed listingId);
    event OfferMade(bytes32 indexed listingId, address buyer, uint256 price);
    event OfferAccepted(bytes32 indexed listingId, uint256 offerIndex);
    
    /**
     * @dev List NFT for sale
     */
    function listNFT(address nftContract, uint256 tokenId, uint256 price) 
        external 
        whenNotPaused 
        returns (bytes32) 
    {
        require(price > 0, "Price must be > 0");
        
        IERC721 nft = IERC721(nftContract);
        require(nft.ownerOf(tokenId) == msg.sender, "Not owner");
        require(nft.isApprovedForAll(msg.sender, address(this)), "Not approved");
        
        bytes32 listingId = keccak256(abi.encodePacked(nftContract, tokenId, msg.sender, block.timestamp));
        
        listings[listingId] = Listing({
            seller: msg.sender,
            nftContract: nftContract,
            tokenId: tokenId,
            price: price,
            active: true
        });
        
        emit Listed(listingId, msg.sender, nftContract, tokenId, price);
        
        return listingId;
    }
    
    /**
     * @dev Buy listed NFT
     */
    function buyNFT(bytes32 listingId) external payable nonReentrant whenNotPaused {
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        require(msg.value >= listing.price, "Insufficient payment");
        
        listing.active = false;
        
        // Calculate fees
        uint256 platformFeeAmount = (listing.price * platformFee) / FEE_DENOMINATOR;
        uint256 royaltyAmount = (listing.price * royalties[listing.nftContract][listing.tokenId]) / FEE_DENOMINATOR;
        uint256 sellerAmount = listing.price - platformFeeAmount - royaltyAmount;
        
        // Transfer NFT
        IERC721(listing.nftContract).safeTransferFrom(listing.seller, msg.sender, listing.tokenId);
        
        // Transfer payments
        payable(listing.seller).transfer(sellerAmount);
        
        // Refund excess
        if (msg.value > listing.price) {
            payable(msg.sender).transfer(msg.value - listing.price);
        }
        
        emit Sold(listingId, msg.sender, listing.price);
    }
    
    /**
     * @dev Cancel listing
     */
    function cancelListing(bytes32 listingId) external {
        Listing storage listing = listings[listingId];
        require(listing.seller == msg.sender, "Not seller");
        require(listing.active, "Not active");
        
        listing.active = false;
        
        emit ListingCancelled(listingId);
    }
    
    /**
     * @dev Make offer on NFT
     */
    function makeOffer(bytes32 listingId, uint256 expiration) external payable {
        require(msg.value > 0, "Offer must be > 0");
        require(expiration > block.timestamp, "Invalid expiration");
        
        Listing storage listing = listings[listingId];
        require(listing.active, "Listing not active");
        
        offers[listingId].push(Offer({
            buyer: msg.sender,
            price: msg.value,
            expiration: expiration,
            active: true
        }));
        
        emit OfferMade(listingId, msg.sender, msg.value);
    }
    
    /**
     * @dev Accept offer
     */
    function acceptOffer(bytes32 listingId, uint256 offerIndex) external nonReentrant {
        Listing storage listing = listings[listingId];
        require(listing.seller == msg.sender, "Not seller");
        require(listing.active, "Not active");
        
        Offer storage offer = offers[listingId][offerIndex];
        require(offer.active, "Offer not active");
        require(offer.expiration > block.timestamp, "Offer expired");
        
        listing.active = false;
        offer.active = false;
        
        // Calculate fees
        uint256 platformFeeAmount = (offer.price * platformFee) / FEE_DENOMINATOR;
        uint256 sellerAmount = offer.price - platformFeeAmount;
        
        // Transfer NFT
        IERC721(listing.nftContract).safeTransferFrom(msg.sender, offer.buyer, listing.tokenId);
        
        // Transfer payment
        payable(msg.sender).transfer(sellerAmount);
        
        emit OfferAccepted(listingId, offerIndex);
    }
    
    /**
     * @dev Set royalty for NFT
     */
    function setRoyalty(address nftContract, uint256 tokenId, uint256 royaltyPercent) external {
        require(royaltyPercent <= 1000, "Royalty too high"); // Max 10%
        require(IERC721(nftContract).ownerOf(tokenId) == msg.sender, "Not owner");
        
        royalties[nftContract][tokenId] = royaltyPercent;
    }
}
```

## Web3 Integration (JavaScript/TypeScript)

### **Ethers.js Integration**
```typescript
import { ethers } from 'ethers';
import { Contract, Wallet, providers } from 'ethers';

interface NetworkConfig {
  chainId: number;
  rpcUrl: string;
  name: string;
}

class Web3Manager {
  private provider: providers.Provider;
  private signer?: Wallet;
  private contracts: Map<string, Contract> = new Map();
  
  constructor(config: NetworkConfig, privateKey?: string) {
    this.provider = new ethers.providers.JsonRpcProvider(config.rpcUrl);
    
    if (privateKey) {
      this.signer = new Wallet(privateKey, this.provider);
    }
  }
  
  /**
   * Connect to MetaMask
   */
  async connectMetaMask(): Promise<string> {
    if (typeof window === 'undefined' || !window.ethereum) {
      throw new Error('MetaMask not installed');
    }
    
    const provider = new ethers.providers.Web3Provider(window.ethereum);
    await provider.send('eth_requestAccounts', []);
    
    const signer = provider.getSigner();
    const address = await signer.getAddress();
    
    this.provider = provider;
    this.signer = signer as any;
    
    return address;
  }
  
  /**
   * Load contract
   */
  loadContract(address: string, abi: any, name: string): Contract {
    const contract = new Contract(address, abi, this.signer || this.provider);
    this.contracts.set(name, contract);
    return contract;
  }
  
  /**
   * Get contract instance
   */
  getContract(name: string): Contract {
    const contract = this.contracts.get(name);
    if (!contract) {
      throw new Error(`Contract ${name} not loaded`);
    }
    return contract;
  }
  
  /**
   * Send transaction with gas optimization
   */
  async sendTransaction(
    contract: Contract,
    method: string,
    args: any[],
    options: {
      value?: string;
      gasLimit?: number;
      maxPriorityFeePerGas?: string;
      maxFeePerGas?: string;
    } = {}
  ): Promise<ethers.ContractTransaction> {
    // Estimate gas
    const estimatedGas = await contract.estimateGas[method](...args, {
      value: options.value ? ethers.utils.parseEther(options.value) : undefined,
    });
    
    // Add 20% buffer
    const gasLimit = options.gasLimit || estimatedGas.mul(120).div(100);
    
    // Get gas prices if not provided
    let maxPriorityFeePerGas = options.maxPriorityFeePerGas;
    let maxFeePerGas = options.maxFeePerGas;
    
    if (!maxFeePerGas) {
      const feeData = await this.provider.getFeeData();
      maxPriorityFeePerGas = feeData.maxPriorityFeePerGas?.toString();
      maxFeePerGas = feeData.maxFeePerGas?.toString();
    }
    
    // Send transaction
    const tx = await contract[method](...args, {
      value: options.value ? ethers.utils.parseEther(options.value) : undefined,
      gasLimit,
      maxPriorityFeePerGas,
      maxFeePerGas,
    });
    
    return tx;
  }
  
  /**
   * Wait for transaction with retries
   */
  async waitForTransaction(
    txHash: string,
    confirmations: number = 1,
    timeout: number = 300000
  ): Promise<ethers.providers.TransactionReceipt> {
    const receipt = await this.provider.waitForTransaction(
      txHash,
      confirmations,
      timeout
    );
    
    if (!receipt) {
      throw new Error('Transaction not found');
    }
    
    if (receipt.status === 0) {
      throw new Error('Transaction failed');
    }
    
    return receipt;
  }
  
  /**
   * Get account balance
   */
  async getBalance(address: string): Promise<string> {
    const balance = await this.provider.getBalance(address);
    return ethers.utils.formatEther(balance);
  }
  
  /**
   * Listen to contract events
   */
  listenToEvents(
    contractName: string,
    eventName: string,
    callback: (...args: any[]) => void
  ): void {
    const contract = this.getContract(contractName);
    contract.on(eventName, callback);
  }
  
  /**
   * Query past events
   */
  async queryEvents(
    contractName: string,
    eventName: string,
    fromBlock: number,
    toBlock: number | 'latest' = 'latest'
  ): Promise<ethers.Event[]> {
    const contract = this.getContract(contractName);
    const filter = contract.filters[eventName]();
    const events = await contract.queryFilter(filter, fromBlock, toBlock);
    return events;
  }
}

/**
 * DeFi Helper Functions
 */
class DeFiHelper {
  private web3: Web3Manager;
  
  constructor(web3Manager: Web3Manager) {
    this.web3 = web3Manager;
  }
  
  /**
   * Swap tokens using Uniswap
   */
  async swapTokens(
    tokenIn: string,
    tokenOut: string,
    amountIn: string,
    minAmountOut: string,
    deadline: number
  ): Promise<ethers.ContractTransaction> {
    const router = this.web3.getContract('UniswapRouter');
    
    const path = [tokenIn, tokenOut];
    const to = await this.web3.signer!.getAddress();
    
    return await this.web3.sendTransaction(
      router,
      'swapExactTokensForTokens',
      [
        ethers.utils.parseEther(amountIn),
        ethers.utils.parseEther(minAmountOut),
        path,
        to,
        deadline,
      ]
    );
  }
  
  /**
   * Add liquidity to pool
   */
  async addLiquidity(
    tokenA: string,
    tokenB: string,
    amountA: string,
    amountB: string,
    minAmountA: string,
    minAmountB: string,
    deadline: number
  ): Promise<ethers.ContractTransaction> {
    const router = this.web3.getContract('UniswapRouter');
    const to = await this.web3.signer!.getAddress();
    
    return await this.web3.sendTransaction(
      router,
      'addLiquidity',
      [
        tokenA,
        tokenB,
        ethers.utils.parseEther(amountA),
        ethers.utils.parseEther(amountB),
        ethers.utils.parseEther(minAmountA),
        ethers.utils.parseEther(minAmountB),
        to,
        deadline,
      ]
    );
  }
  
  /**
   * Calculate optimal swap amount
   */
  async getAmountsOut(amountIn: string, path: string[]): Promise<string[]> {
    const router = this.web3.getContract('UniswapRouter');
    const amounts = await router.getAmountsOut(
      ethers.utils.parseEther(amountIn),
      path
    );
    return amounts.map((a: ethers.BigNumber) => ethers.utils.formatEther(a));
  }
}
```

## Gas Optimization Patterns

### **Gas-Efficient Contract Patterns**
```solidity
// Gas optimization techniques

// 1. Use uint256 instead of smaller uints (unless packing)
uint256 public count; // More gas efficient than uint8

// 2. Pack storage variables
struct User {
    address addr;        // 20 bytes
    uint96 balance;      // 12 bytes - fits in same slot
    bool active;         // 1 byte - still same slot
}

// 3. Use immutable for constants set in constructor
address public immutable owner;

// 4. Use memory instead of storage when possible
function processArray(uint256[] memory arr) public {
    // More efficient than storage array
}

// 5. Short-circuit with require statements
function transfer(address to, uint256 amount) public {
    require(to != address(0), "Invalid address"); // Check first
    require(balances[msg.sender] >= amount, "Insufficient balance");
    // ... rest of logic
}

// 6. Use events instead of storage for historical data
event Transfer(address indexed from, address indexed to, uint256 value);

// 7. Batch operations
function batchTransfer(address[] calldata recipients, uint256[] calldata amounts) external {
    require(recipients.length == amounts.length, "Length mismatch");
    
    for (uint256 i = 0; i < recipients.length; i++) {
        _transfer(msg.sender, recipients[i], amounts[i]);
    }
}

// 8. Use unchecked for safe arithmetic (Solidity 0.8+)
function increment() external {
    unchecked {
        counter++; // Save gas if overflow is impossible
    }
}
```

## Security Best Practices

### **Security Checklist**
```typescript
const securityChecklist = {
  reentrancy: {
    solution: "Use ReentrancyGuard from OpenZeppelin",
    pattern: "Checks-Effects-Interactions pattern"
  },
  
  integerOverflow: {
    solution: "Use Solidity 0.8+ with automatic checks",
    alternative: "Use SafeMath library for older versions"
  },
  
  accessControl: {
    solution: "Use OpenZeppelin AccessControl",
    patterns: ["Ownable", "Role-based access control"]
  },
  
  frontRunning: {
    solutions: [
      "Commit-reveal schemes",
      "Batch auctions",
      "Flashbots integration"
    ]
  },
  
  oracleManipulation: {
    solutions: [
      "Use Chainlink price feeds",
      "Time-weighted average prices (TWAP)",
      "Multiple oracle sources"
    ]
  },
  
  flashLoanAttacks: {
    solutions: [
      "Reentrancy guards",
      "Balance checks",
      "TWAP for prices"
    ]
  }
};
