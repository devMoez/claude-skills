## Neural-Symbolic Integration

### **Hybrid Architecture**
```python
import torch
import torch.nn as nn
from typing import List, Dict, Tuple
import networkx as nx

class NeurosymbolicEngine:
    """
    Core neurosymbolic reasoning engine combining neural perception
    with symbolic reasoning
    """
    
    def __init__(self, neural_model: nn.Module, knowledge_graph: nx.DiGraph):
        self.neural_model = neural_model
        self.knowledge_graph = knowledge_graph
        self.reasoning_engine = LogicReasoner(knowledge_graph)
        self.neural_symbolic_bridge = NeuralSymbolicBridge()
    
    def perceive_and_reason(self, input_data: torch.Tensor) -> Dict:
        """
        End-to-end neurosymbolic inference
        
        1. Neural perception extracts features/concepts
        2. Symbolic reasoning applies logic rules
        3. Integrated output combines both
        """
        # Step 1: Neural perception
        neural_output = self.neural_model(input_data)
        concepts = self.neural_symbolic_bridge.neural_to_symbolic(neural_output)
        
        # Step 2: Symbolic reasoning
        reasoning_result = self.reasoning_engine.infer(concepts)
        
        # Step 3: Combine results
        integrated_output = self._integrate_results(
            neural_output,
            reasoning_result
        )
        
        return integrated_output
    
    def _integrate_results(
        self,
        neural_output: torch.Tensor,
        symbolic_output: Dict
    ) -> Dict:
        """Integrate neural and symbolic results"""
        return {
            'perception': neural_output,
            'reasoning': symbolic_output,
            'explanation': self._generate_explanation(symbolic_output),
            'confidence': self._compute_confidence(neural_output, symbolic_output)
        }
    
    def _generate_explanation(self, symbolic_output: Dict) -> str:
        """Generate human-readable explanation"""
        rules_used = symbolic_output.get('rules_used', [])
        
        explanation = "Reasoning chain:\n"
        for i, rule in enumerate(rules_used, 1):
            explanation += f"{i}. {rule['premise']} → {rule['conclusion']}\n"
        
        return explanation
    
    def _compute_confidence(
        self,
        neural_output: torch.Tensor,
        symbolic_output: Dict
    ) -> float:
        """Compute integrated confidence score"""
        neural_conf = torch.max(torch.softmax(neural_output, dim=-1)).item()
        symbolic_conf = symbolic_output.get('confidence', 1.0)
        
        # Weighted combination
        return 0.6 * neural_conf + 0.4 * symbolic_conf


class LogicReasoner:
    """Symbolic reasoning engine using first-order logic"""
    
    def __init__(self, knowledge_graph: nx.DiGraph):
        self.kg = knowledge_graph
        self.rules = []
        self.facts = set()
    
    def add_rule(self, premise: str, conclusion: str, confidence: float = 1.0):
        """Add logical rule"""
        self.rules.append({
            'premise': premise,
            'conclusion': conclusion,
            'confidence': confidence
        })
    
    def add_fact(self, fact: str):
        """Add known fact"""
        self.facts.add(fact)
    
    def infer(self, observations: List[str]) -> Dict:
        """Forward chaining inference"""
        # Start with observed facts
        working_memory = set(observations) | self.facts
        rules_used = []
        
        # Iteratively apply rules
        changed = True
        iterations = 0
        max_iterations = 100
        
        while changed and iterations < max_iterations:
            changed = False
            iterations += 1
            
            for rule in self.rules:
                if self._premises_satisfied(rule['premise'], working_memory):
                    conclusion = rule['conclusion']
                    
                    if conclusion not in working_memory:
                        working_memory.add(conclusion)
                        rules_used.append(rule)
                        changed = True
        
        return {
            'inferred_facts': list(working_memory - set(observations) - self.facts),
            'rules_used': rules_used,
            'confidence': min([r['confidence'] for r in rules_used]) if rules_used else 1.0
        }
    
    def _premises_satisfied(self, premise: str, facts: set) -> bool:
        """Check if all premises are in facts"""
        # Parse premise (simplified - assumes AND logic)
        premises = [p.strip() for p in premise.split('AND')]
        return all(p in facts for p in premises)
    
    def backward_chain(self, goal: str) -> List[str]:
        """Backward chaining to find proof"""
        proof_chain = []
        
        def search(g: str) -> bool:
            if g in self.facts:
                return True
            
            for rule in self.rules:
                if rule['conclusion'] == g:
                    premise = rule['premise']
                    premises = [p.strip() for p in premise.split('AND')]
                    
                    if all(search(p) for p in premises):
                        proof_chain.append(rule)
                        return True
            
            return False
        
        found = search(goal)
        
        return proof_chain if found else []


class NeuralSymbolicBridge:
    """Bridge between neural and symbolic representations"""
    
    def __init__(self, threshold: float = 0.7):
        self.threshold = threshold
        self.concept_mapping = {}
    
    def neural_to_symbolic(self, neural_output: torch.Tensor) -> List[str]:
        """Convert neural network output to symbolic concepts"""
        # Apply threshold to neural activations
        probs = torch.softmax(neural_output, dim=-1)
        
        concepts = []
        for idx, prob in enumerate(probs.squeeze()):
            if prob.item() > self.threshold:
                concept = self.concept_mapping.get(idx, f"concept_{idx}")
                concepts.append(concept)
        
        return concepts
    
    def symbolic_to_neural(self, concepts: List[str]) -> torch.Tensor:
        """Convert symbolic concepts to neural representation"""
        # Create one-hot or embedding representation
        indices = [self._concept_to_index(c) for c in concepts]
        
        embedding = torch.zeros(len(self.concept_mapping))
        for idx in indices:
            embedding[idx] = 1.0
        
        return embedding
    
    def register_concept(self, concept_name: str, neural_index: int):
        """Register mapping between concept and neural index"""
        self.concept_mapping[neural_index] = concept_name
    
    def _concept_to_index(self, concept: str) -> int:
        """Get neural index for concept"""
        for idx, name in self.concept_mapping.items():
            if name == concept:
                return idx
        return -1
```

### **Knowledge Graph Integration**
```python
import networkx as nx
from typing import List, Tuple
import torch
from torch_geometric.data import Data
from torch_geometric.nn import GCNConv, GATConv

class KnowledgeGraphNN(nn.Module):
    """Graph Neural Network over knowledge graph"""
    
    def __init__(
        self,
        num_nodes: int,
        num_relations: int,
        embedding_dim: int = 128,
        hidden_dim: int = 256
    ):
        super().__init__()
        
        self.entity_embeddings = nn.Embedding(num_nodes, embedding_dim)
        self.relation_embeddings = nn.Embedding(num_relations, embedding_dim)
        
        # Graph convolution layers
        self.conv1 = GATConv(embedding_dim, hidden_dim, heads=4)
        self.conv2 = GATConv(hidden_dim * 4, hidden_dim, heads=4)
        self.conv3 = GATConv(hidden_dim * 4, embedding_dim, heads=1)
        
        self.dropout = nn.Dropout(0.3)
    
    def forward(self, data: Data) -> torch.Tensor:
        """Forward pass through knowledge graph"""
        x = self.entity_embeddings(data.x)
        edge_index = data.edge_index
        
        # Graph convolutions
        x = self.conv1(x, edge_index)
        x = torch.relu(x)
        x = self.dropout(x)
        
        x = self.conv2(x, edge_index)
        x = torch.relu(x)
        x = self.dropout(x)
        
        x = self.conv3(x, edge_index)
        
        return x
    
    def predict_link(
        self,
        head: int,
        relation: int,
        tail: int
    ) -> float:
        """Predict probability of (head, relation, tail) triple"""
        head_emb = self.entity_embeddings(torch.tensor([head]))
        rel_emb = self.relation_embeddings(torch.tensor([relation]))
        tail_emb = self.entity_embeddings(torch.tensor([tail]))
        
        # TransE-style scoring
        score = torch.norm(head_emb + rel_emb - tail_emb, p=2)
        prob = torch.sigmoid(-score)
        
        return prob.item()


class HybridKnowledgeReasoner:
    """Combines neural and symbolic knowledge reasoning"""
    
    def __init__(
        self,
        knowledge_graph: nx.DiGraph,
        gnn_model: KnowledgeGraphNN
    ):
        self.kg = knowledge_graph
        self.gnn = gnn_model
        self.entity_to_id = {node: i for i, node in enumerate(knowledge_graph.nodes())}
        self.id_to_entity = {i: node for node, i in self.entity_to_id.items()}
    
    def query(
        self,
        head: str,
        relation: str,
        tail: str = None,
        method: str = 'hybrid'
    ) -> List[Tuple[str, float]]:
        """
        Query knowledge graph
        
        Methods:
        - 'symbolic': Pure graph traversal
        - 'neural': GNN-based prediction
        - 'hybrid': Combination of both
        """
        if method == 'symbolic':
            return self._symbolic_query(head, relation, tail)
        elif method == 'neural':
            return self._neural_query(head, relation, tail)
        else:
            return self._hybrid_query(head, relation, tail)
    
    def _symbolic_query(
        self,
        head: str,
        relation: str,
        tail: str
    ) -> List[Tuple[str, float]]:
        """Symbolic graph traversal"""
        results = []
        
        if tail is None:
            # Find all tails for (head, relation, ?)
            for neighbor in self.kg.neighbors(head):
                edge_data = self.kg.get_edge_data(head, neighbor)
                
                if edge_data and edge_data.get('relation') == relation:
                    confidence = edge_data.get('confidence', 1.0)
                    results.append((neighbor, confidence))
        else:
            # Check if (head, relation, tail) exists
            if self.kg.has_edge(head, tail):
                edge_data = self.kg.get_edge_data(head, tail)
                
                if edge_data.get('relation') == relation:
                    confidence = edge_data.get('confidence', 1.0)
                    results.append((tail, confidence))
        
        return sorted(results, key=lambda x: x[1], reverse=True)
    
    def _neural_query(
        self,
        head: str,
        relation: str,
        tail: str
    ) -> List[Tuple[str, float]]:
        """Neural GNN prediction"""
        head_id = self.entity_to_id.get(head)
        rel_id = self._get_relation_id(relation)
        
        if tail is None:
            # Predict all possible tails
            results = []
            for entity, entity_id in self.entity_to_id.items():
                if entity != head:
                    prob = self.gnn.predict_link(head_id, rel_id, entity_id)
                    results.append((entity, prob))
            
            return sorted(results, key=lambda x: x[1], reverse=True)[:10]
        else:
            # Predict specific triple
            tail_id = self.entity_to_id.get(tail)
            prob = self.gnn.predict_link(head_id, rel_id, tail_id)
            
            return [(tail, prob)]
    
    def _hybrid_query(
        self,
        head: str,
        relation: str,
        tail: str
    ) -> List[Tuple[str, float]]:
        """Hybrid symbolic + neural query"""
        # Get symbolic results
        symbolic_results = self._symbolic_query(head, relation, tail)
        symbolic_dict = dict(symbolic_results)
        
        # Get neural results
        neural_results = self._neural_query(head, relation, tail)
        
        # Combine with weighted average
        combined = {}
        all_entities = set(symbolic_dict.keys()) | set(dict(neural_results).keys())
        
        for entity in all_entities:
            symbolic_conf = symbolic_dict.get(entity, 0.0)
            neural_conf = dict(neural_results).get(entity, 0.0)
            
            # Weight symbolic higher if it exists
            if entity in symbolic_dict:
                combined[entity] = 0.7 * symbolic_conf + 0.3 * neural_conf
            else:
                combined[entity] = neural_conf
        
        return sorted(combined.items(), key=lambda x: x[1], reverse=True)
    
    def _get_relation_id(self, relation: str) -> int:
        """Get numeric ID for relation"""
        # Simplified - should maintain relation vocabulary
        return hash(relation) % 100
```

### **Explainable AI with Logic**
```python
class ExplainableNeurosymbolicModel:
    """Neurosymbolic model with built-in explainability"""
    
    def __init__(
        self,
        neural_model: nn.Module,
        logic_rules: List[Dict],
        knowledge_graph: nx.DiGraph
    ):
        self.neural_model = neural_model
        self.logic_rules = logic_rules
        self.kg = knowledge_graph
        self.explanation_generator = ExplanationGenerator()
    
    def predict_with_explanation(
        self,
        input_data: torch.Tensor
    ) -> Tuple[torch.Tensor, str]:
        """Make prediction and generate explanation"""
        # Neural prediction
        with torch.no_grad():
            neural_output = self.neural_model(input_data)
            neural_pred = torch.argmax(neural_output, dim=-1)
        
        # Extract activated concepts
        activated_concepts = self._extract_concepts(neural_output)
        
        # Apply logic rules
        logic_result = self._apply_logic(activated_concepts)
        
        # Generate explanation
        explanation = self.explanation_generator.generate(
            neural_pred=neural_pred,
            concepts=activated_concepts,
            logic_result=logic_result,
            rules_used=logic_result.get('rules_used', [])
        )
        
        return neural_pred, explanation
    
    def _extract_concepts(self, neural_output: torch.Tensor) -> List[str]:
        """Extract high-level concepts from neural activations"""
        # Use attention weights or activation patterns
        concepts = []
        
        # Simplified extraction
        probs = torch.softmax(neural_output, dim=-1)
        top_k = torch.topk(probs, k=5)
        
        for idx in top_k.indices.squeeze():
            concepts.append(f"concept_{idx.item()}")
        
        return concepts
    
    def _apply_logic(self, concepts: List[str]) -> Dict:
        """Apply logical reasoning to concepts"""
        inferred = set()
        rules_used = []
        
        for rule in self.logic_rules:
            premises = rule['premises']
            
            if all(p in concepts for p in premises):
                conclusion = rule['conclusion']
                inferred.add(conclusion)
                rules_used.append(rule)
        
        return {
            'inferred_facts': list(inferred),
            'rules_used': rules_used
        }


class ExplanationGenerator:
    """Generate human-readable explanations"""
    
    def generate(
        self,
        neural_pred: torch.Tensor,
        concepts: List[str],
        logic_result: Dict,
        rules_used: List[Dict]
    ) -> str:
        """Generate comprehensive explanation"""
        explanation = []
        
        # Neural perception explanation
        explanation.append("## Perception")
        explanation.append(f"The model detected the following concepts:")
        for concept in concepts[:5]:
            explanation.append(f"  - {concept}")
        
        # Logical reasoning explanation
        explanation.append("\n## Reasoning")
        if rules_used:
            explanation.append("Applied the following logical rules:")
            for i, rule in enumerate(rules_used, 1):
                premises = " AND ".join(rule['premises'])
                conclusion = rule['conclusion']
                explanation.append(f"  {i}. IF {premises} THEN {conclusion}")
        else:
            explanation.append("No logical rules were triggered.")
        
        # Final decision explanation
        explanation.append("\n## Decision")
        explanation.append(f"Based on the above reasoning, the prediction is: {neural_pred.item()}")
        
        # Confidence
        inferred_facts = logic_result.get('inferred_facts', [])
        if inferred_facts:
            explanation.append(f"\nAdditional inferred facts: {', '.join(inferred_facts)}")
        
        return "\n".join(explanation)
```

