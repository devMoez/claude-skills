## Artificial Immune Systems

### **Clonal Selection Algorithm**
```python
class ClonalSelectionAlgorithm:
    """
    Artificial Immune System for optimization
    Based on clonal selection principle
    """
    
    def __init__(self, population_size: int = 100, clone_factor: int = 10):
        self.population_size = population_size
        self.clone_factor = clone_factor
        self.antibodies = []
    
    def optimize(
        self,
        objective_func: Callable,
        dimensions: int,
        bounds: Tuple,
        max_iterations: int = 100
    ):
        """Run clonal selection optimization"""
        lower, upper = bounds
        
        # Initialize antibody population
        self._initialize_population(dimensions, lower, upper)
        
        for iteration in range(max_iterations):
            # Evaluate affinities
            affinities = [objective_func(ab) for ab in self.antibodies]
            
            # Select best
            best_indices = np.argsort(affinities)[:self.population_size // 2]
            
            # Clone proportional to affinity
            clones = []
            for idx in best_indices:
                n_clones = int(self.clone_factor * (1 - affinities[idx] / max(affinities)))
                
                for _ in range(n_clones):
                    clone = self._hypermutate(self.antibodies[idx], affinities[idx])
                    clones.append(clone)
            
            # Select best clones
            clone_affinities = [objective_func(c) for c in clones]
            best_clones = [clones[i] for i in np.argsort(clone_affinities)[:self.population_size // 2]]
            
            # Replace worst antibodies
            self.antibodies = (
                [self.antibodies[i] for i in best_indices] +
                best_clones
            )
            
            # Add random antibodies (diversity)
            n_random = self.population_size - len(self.antibodies)
            for _ in range(n_random):
                random_ab = lower + np.random.rand(dimensions) * (upper - lower)
                self.antibodies.append(random_ab)
            
            best_affinity = min(affinities)
            print(f"Iteration {iteration}: Best = {best_affinity:.6f}")
        
        affinities = [objective_func(ab) for ab in self.antibodies]
        best_idx = np.argmin(affinities)
        
        return self.antibodies[best_idx], affinities[best_idx]
    
    def _initialize_population(self, dimensions, lower, upper):
        """Initialize antibody population"""
        for _ in range(self.population_size):
            antibody = lower + np.random.rand(dimensions) * (upper - lower)
            self.antibodies.append(antibody)
    
    def _hypermutate(self, antibody: np.ndarray, affinity: float) -> np.ndarray:
        """Hypermutation inversely proportional to affinity"""
        mutation_rate = np.exp(-affinity)
        mutated = antibody + np.random.randn(len(antibody)) * mutation_rate
        
        return mutated
```

