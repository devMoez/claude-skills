## Agent Architectures

### **Multi-Agent Framework**
```python
from typing import Dict, List, Any, Optional, Callable
from dataclasses import dataclass, field
from enum import Enum
import asyncio
from abc import ABC, abstractmethod

class AgentRole(Enum):
    COORDINATOR = "coordinator"
    EXECUTOR = "executor"
    ANALYZER = "analyzer"
    VALIDATOR = "validator"
    OPTIMIZER = "optimizer"

class MessageType(Enum):
    TASK = "task"
    RESULT = "result"
    QUERY = "query"
    BROADCAST = "broadcast"
    ERROR = "error"

@dataclass
class Message:
    """Inter-agent communication message"""
    sender: str
    recipient: str
    msg_type: MessageType
    content: Any
    metadata: Dict[str, Any] = field(default_factory=dict)
    timestamp: float = field(default_factory=lambda: time.time())

@dataclass
class AgentCapability:
    """Agent capability definition"""
    name: str
    description: str
    input_schema: Dict[str, Any]
    output_schema: Dict[str, Any]
    execute: Callable

class BaseAgent(ABC):
    """Base agent with communication and task execution"""
    
    def __init__(self, agent_id: str, role: AgentRole, capabilities: List[AgentCapability]):
        self.agent_id = agent_id
        self.role = role
        self.capabilities = {cap.name: cap for cap in capabilities}
        self.message_queue: asyncio.Queue = asyncio.Queue()
        self.knowledge_base: Dict[str, Any] = {}
        self.performance_metrics: Dict[str, float] = {}
        
    @abstractmethod
    async def process_task(self, task: Dict[str, Any]) -> Any:
        """Process assigned task"""
        pass
    
    async def send_message(self, recipient: str, msg_type: MessageType, content: Any):
        """Send message to another agent"""
        message = Message(
            sender=self.agent_id,
            recipient=recipient,
            msg_type=msg_type,
            content=content
        )
        await self.orchestrator.route_message(message)
    
    async def receive_message(self) -> Message:
        """Receive message from queue"""
        return await self.message_queue.get()
    
    async def run(self):
        """Main agent event loop"""
        while True:
            message = await self.receive_message()
            await self.handle_message(message)
    
    async def handle_message(self, message: Message):
        """Handle incoming message"""
        if message.msg_type == MessageType.TASK:
            result = await self.process_task(message.content)
            await self.send_message(
                message.sender,
                MessageType.RESULT,
                result
            )
        elif message.msg_type == MessageType.QUERY:
            response = await self.answer_query(message.content)
            await self.send_message(message.sender, MessageType.RESULT, response)
    
    def update_knowledge(self, key: str, value: Any):
        """Update agent knowledge base"""
        self.knowledge_base[key] = value
    
    def get_capability(self, name: str) -> Optional[AgentCapability]:
        """Get agent capability by name"""
        return self.capabilities.get(name)

class CoordinatorAgent(BaseAgent):
    """Coordinates multiple agents to complete complex tasks"""
    
    def __init__(self, agent_id: str):
        super().__init__(agent_id, AgentRole.COORDINATOR, [])
        self.task_queue: List[Dict] = []
        self.agent_registry: Dict[str, BaseAgent] = {}
    
    def register_agent(self, agent: BaseAgent):
        """Register agent in the system"""
        self.agent_registry[agent.agent_id] = agent
        agent.orchestrator = self
    
    async def process_task(self, task: Dict[str, Any]) -> Any:
        """Decompose and delegate task to appropriate agents"""
        # Task decomposition
        subtasks = await self.decompose_task(task)
        
        # Assign to agents
        assignments = await self.assign_subtasks(subtasks)
        
        # Execute in parallel
        results = await asyncio.gather(*[
            self.execute_subtask(agent_id, subtask)
            for agent_id, subtask in assignments
        ])
        
        # Aggregate results
        final_result = await self.aggregate_results(results)
        return final_result
    
    async def decompose_task(self, task: Dict[str, Any]) -> List[Dict]:
        """Break complex task into subtasks"""
        subtasks = []
        
        # Analyze task dependencies
        task_graph = self.build_task_graph(task)
        
        # Topological sort for execution order
        execution_order = self.topological_sort(task_graph)
        
        for node in execution_order:
            subtasks.append({
                'id': node,
                'type': task_graph[node]['type'],
                'dependencies': task_graph[node].get('dependencies', []),
                'params': task_graph[node].get('params', {})
            })
        
        return subtasks
    
    async def assign_subtasks(self, subtasks: List[Dict]) -> List[tuple]:
        """Assign subtasks to optimal agents"""
        assignments = []
        
        for subtask in subtasks:
            # Find agents with required capabilities
            capable_agents = [
                agent for agent in self.agent_registry.values()
                if self.can_handle_task(agent, subtask)
            ]
            
            if not capable_agents:
                raise ValueError(f"No agent can handle subtask: {subtask}")
            
            # Select best agent based on performance metrics
            best_agent = max(
                capable_agents,
                key=lambda a: a.performance_metrics.get(subtask['type'], 0.5)
            )
            
            assignments.append((best_agent.agent_id, subtask))
        
        return assignments
    
    async def execute_subtask(self, agent_id: str, subtask: Dict) -> Any:
        """Execute subtask via assigned agent"""
        await self.send_message(agent_id, MessageType.TASK, subtask)
        
        # Wait for result
        result_message = await self.wait_for_result(agent_id)
        return result_message.content
    
    def can_handle_task(self, agent: BaseAgent, task: Dict) -> bool:
        """Check if agent can handle task"""
        task_type = task.get('type')
        return task_type in agent.capabilities
    
    async def route_message(self, message: Message):
        """Route message to recipient agent"""
        if message.recipient in self.agent_registry:
            await self.agent_registry[message.recipient].message_queue.put(message)

class DataProcessorAgent(BaseAgent):
    """Agent specialized in data processing and transformation"""
    
    def __init__(self, agent_id: str):
        capabilities = [
            AgentCapability(
                name="clean_data",
                description="Clean and normalize data",
                input_schema={"data": "any"},
                output_schema={"cleaned_data": "any"},
                execute=self.clean_data
            ),
            AgentCapability(
                name="transform_data",
                description="Transform data format",
                input_schema={"data": "any", "format": "str"},
                output_schema={"transformed_data": "any"},
                execute=self.transform_data
            ),
        ]
        super().__init__(agent_id, AgentRole.EXECUTOR, capabilities)
    
    async def process_task(self, task: Dict[str, Any]) -> Any:
        """Process data task"""
        task_type = task.get('type')
        capability = self.get_capability(task_type)
        
        if not capability:
            raise ValueError(f"Unknown task type: {task_type}")
        
        result = await capability.execute(task.get('params', {}))
        
        # Update performance metrics
        self.performance_metrics[task_type] = self.performance_metrics.get(task_type, 0.5) + 0.1
        
        return result
    
    async def clean_data(self, params: Dict) -> Dict:
        """Clean data implementation"""
        data = params.get('data', [])
        # Cleaning logic
        cleaned = [item for item in data if item is not None]
        return {"cleaned_data": cleaned}
    
    async def transform_data(self, params: Dict) -> Dict:
        """Transform data implementation"""
        data = params.get('data')
        format_type = params.get('format', 'json')
        # Transformation logic
        return {"transformed_data": data, "format": format_type}

class AnalyzerAgent(BaseAgent):
