## Genetic Programming for Code

### **Code Evolution Engine**
```python
import ast
import astor
from typing import List, Callable, Dict, Any
import random
import numpy as np
from dataclasses import dataclass

@dataclass
class CodeIndividual:
    """Represents a code variant in the evolution population"""
    code: str
    ast_tree: ast.AST
    fitness: float = 0.0
    generation: int = 0
    mutations: List[str] = None
    
    def __post_init__(self):
        if self.mutations is None:
            self.mutations = []


class AutonomousCodeEvolver:
    """
    Evolves code autonomously using genetic programming
    """
    
    def __init__(
        self,
        population_size: int = 50,
        mutation_rate: float = 0.3,
        crossover_rate: float = 0.7,
        elitism_rate: float = 0.1
    ):
        self.population_size = population_size
        self.mutation_rate = mutation_rate
        self.crossover_rate = crossover_rate
        self.elitism_rate = elitism_rate
        
        self.population: List[CodeIndividual] = []
        self.generation = 0
        self.best_individual = None
        self.fitness_history = []
    
    def initialize_population(self, seed_code: str) -> None:
        """Create initial population from seed code"""
        tree = ast.parse(seed_code)
        
        for _ in range(self.population_size):
            # Create variants with slight mutations
            variant_tree = self._mutate_ast(tree.deepcopy())
            variant_code = astor.to_source(variant_tree)
            
            individual = CodeIndividual(
                code=variant_code,
                ast_tree=variant_tree,
                generation=0
            )
            self.population.append(individual)
    
    def evolve(
        self,
        fitness_function: Callable[[str], float],
        num_generations: int = 100,
        early_stop_threshold: float = 0.99
    ) -> CodeIndividual:
        """Main evolution loop"""
        
        for gen in range(num_generations):
            self.generation = gen
            
            # Evaluate fitness
            self._evaluate_population(fitness_function)
            
            # Track best
            current_best = max(self.population, key=lambda x: x.fitness)
            
            if self.best_individual is None or current_best.fitness > self.best_individual.fitness:
                self.best_individual = current_best
            
            self.fitness_history.append(current_best.fitness)
            
            print(f"Generation {gen}: Best Fitness = {current_best.fitness:.4f}")
            
            # Early stopping
            if current_best.fitness >= early_stop_threshold:
                print(f"Early stop at generation {gen}")
                break
            
            # Create next generation
            self._create_next_generation()
        
        return self.best_individual
    
    def _evaluate_population(self, fitness_function: Callable[[str], float]):
        """Evaluate fitness for all individuals"""
        for individual in self.population:
            try:
                individual.fitness = fitness_function(individual.code)
            except Exception as e:
                # Invalid code gets zero fitness
                individual.fitness = 0.0
    
    def _create_next_generation(self):
        """Create next generation using selection, crossover, mutation"""
        # Sort by fitness
        self.population.sort(key=lambda x: x.fitness, reverse=True)
        
        # Elitism: keep top individuals
        elite_count = int(self.population_size * self.elitism_rate)
        next_gen = self.population[:elite_count]
        
        # Generate rest through crossover and mutation
        while len(next_gen) < self.population_size:
            # Selection
            parent1 = self._tournament_selection()
            parent2 = self._tournament_selection()
            
            # Crossover
            if random.random() < self.crossover_rate:
                child = self._crossover(parent1, parent2)
            else:
                child = parent1
            
            # Mutation
            if random.random() < self.mutation_rate:
                child = self._mutate(child)
            
            child.generation = self.generation + 1
            next_gen.append(child)
        
        self.population = next_gen
    
    def _tournament_selection(self, tournament_size: int = 3) -> CodeIndividual:
        """Tournament selection"""
        tournament = random.sample(self.population, tournament_size)
        return max(tournament, key=lambda x: x.fitness)
    
    def _crossover(self, parent1: CodeIndividual, parent2: CodeIndividual) -> CodeIndividual:
        """Crossover two code individuals"""
        tree1 = parent1.ast_tree
        tree2 = parent2.ast_tree
        
        # Find compatible nodes
        nodes1 = list(ast.walk(tree1))
        nodes2 = list(ast.walk(tree2))
        
        # Select random subtrees of same type
        for _ in range(10):  # Try up to 10 times
            node1 = random.choice(nodes1)
            node2 = random.choice([n for n in nodes2 if type(n) == type(node1)])
            
            if node2:
                # Swap subtrees
                child_tree = self._swap_subtrees(tree1, node1, node2)
                child_code = astor.to_source(child_tree)
                
                return CodeIndividual(
                    code=child_code,
                    ast_tree=child_tree,
                    mutations=['crossover']
                )
        
        # Fallback: return parent1
        return parent1
    
    def _mutate(self, individual: CodeIndividual) -> CodeIndividual:
        """Mutate code individual"""
        mutated_tree = self._mutate_ast(individual.ast_tree)
        mutated_code = astor.to_source(mutated_tree)
        
        return CodeIndividual(
            code=mutated_code,
            ast_tree=mutated_tree,
            mutations=individual.mutations + ['mutation']
        )
    
    def _mutate_ast(self, tree: ast.AST) -> ast.AST:
        """Apply mutations to AST"""
        mutator = ASTMutator()
        mutated = mutator.visit(tree)
        ast.fix_missing_locations(mutated)
        return mutated
    
    def _swap_subtrees(self, tree: ast.AST, node1: ast.AST, node2: ast.AST) -> ast.AST:
        """Swap two subtrees in AST"""
        # Simplified implementation
        # In practice, need careful parent tracking
        return tree


class ASTMutator(ast.NodeTransformer):
    """Mutates Python AST"""
    
    def visit_BinOp(self, node):
        """Mutate binary operations"""
        if random.random() < 0.1:
            # Change operator
            ops = [ast.Add(), ast.Sub(), ast.Mult(), ast.Div()]
            node.op = random.choice(ops)
        
        self.generic_visit(node)
        return node
    
    def visit_Compare(self, node):
        """Mutate comparison operations"""
        if random.random() < 0.1:
            # Change comparator
            ops = [ast.Lt(), ast.LtE(), ast.Gt(), ast.GtE(), ast.Eq(), ast.NotEq()]
            node.ops = [random.choice(ops)]
        
        self.generic_visit(node)
        return node
    
    def visit_Constant(self, node):
        """Mutate constants"""
        if random.random() < 0.05:
            if isinstance(node.value, (int, float)):
                # Adjust numeric constant
                node.value *= random.uniform(0.8, 1.2)
        
        return node
    
    def visit_FunctionDef(self, node):
        """Mutate function definitions"""
        if random.random() < 0.05:
            # Add or remove statements
            if len(node.body) > 1 and random.random() < 0.5:
                # Remove a statement
                node.body.pop(random.randrange(len(node.body)))
        
        self.generic_visit(node)
        return node


# Fitness functions
class FitnessEvaluator:
    """Evaluates code fitness across multiple dimensions"""
    
    def __init__(self, test_cases: List[Dict], target_metrics: Dict[str, float]):
        self.test_cases = test_cases
        self.target_metrics = target_metrics
    
    def evaluate(self, code: str) -> float:
        """Comprehensive fitness evaluation"""
        scores = []
        
        # 1. Correctness (most important)
        correctness = self._evaluate_correctness(code)
        scores.append(correctness * 0.5)
        
        # 2. Performance
        performance = self._evaluate_performance(code)
        scores.append(performance * 0.2)
        
        # 3. Code quality
        quality = self._evaluate_quality(code)
        scores.append(quality * 0.15)
        
        # 4. Maintainability
        maintainability = self._evaluate_maintainability(code)
        scores.append(maintainability * 0.15)
        
        return sum(scores)
    
    def _evaluate_correctness(self, code: str) -> float:
        """Test against test cases"""
        passed = 0
        
        for test_case in self.test_cases:
            try:
                # Execute code with test input
                namespace = {}
                exec(code, namespace)
                
                # Get function (assume main function name)
                func = namespace.get('solution') or namespace.get('main')
                
                if func:
                    result = func(*test_case['input'])
                    
                    if result == test_case['expected']:
                        passed += 1
            except Exception:
                pass
        
        return passed / len(self.test_cases) if self.test_cases else 0.0
    
    def _evaluate_performance(self, code: str) -> float:
        """Measure execution performance"""
        import time
        
        try:
            namespace = {}
            exec(code, namespace)
            func = namespace.get('solution') or namespace.get('main')
            
            if func and self.test_cases:
                start = time.time()
                
                for test_case in self.test_cases[:10]:  # Sample
                    func(*test_case['input'])
                
                elapsed = time.time() - start
                
                # Score: faster is better
                target_time = self.target_metrics.get('max_time', 1.0)
                return max(0.0, 1.0 - (elapsed / target_time))
            
        except Exception:
            pass
        
        return 0.0
    
    def _evaluate_quality(self, code: str) -> float:
        """Evaluate code quality metrics"""
        scores = []
        
        # Lines of code (shorter is often better)
        loc = len(code.split('\n'))
        target_loc = self.target_metrics.get('target_loc', 50)
        loc_score = 1.0 - min(1.0, abs(loc - target_loc) / target_loc)
        scores.append(loc_score)
        
        # Cyclomatic complexity
        try:
            tree = ast.parse(code)
            complexity = self._calculate_complexity(tree)
            complexity_score = max(0.0, 1.0 - (complexity / 20.0))
            scores.append(complexity_score)
        except:
            scores.append(0.0)
        
        return np.mean(scores)
    
    def _evaluate_maintainability(self, code: str) -> float:
        """Evaluate maintainability"""
        # Simplified: check for comments, function decomposition, naming
        scores = []
        
        # Has comments
        has_comments = '#' in code or '"""' in code
        scores.append(1.0 if has_comments else 0.5)
        
        # Function decomposition
        try:
            tree = ast.parse(code)
            num_functions = sum(1 for _ in ast.walk(tree) if isinstance(_, ast.FunctionDef))
            scores.append(min(1.0, num_functions / 3))
        except:
            scores.append(0.0)
        
        return np.mean(scores)
    
    def _calculate_complexity(self, tree: ast.AST) -> int:
        """Calculate cyclomatic complexity"""
        complexity = 1
        
        for node in ast.walk(tree):
            if isinstance(node, (ast.If, ast.While, ast.For, ast.ExceptHandler)):
                complexity += 1
            elif isinstance(node, ast.BoolOp):
                complexity += len(node.values) - 1
        
        return complexity
