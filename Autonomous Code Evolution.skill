### **Reinforcement Learning for Code**
```python
import torch
import torch.nn as nn
from torch.distributions import Categorical

class CodeRLAgent(nn.Module):
    """RL agent for code generation/refactoring"""
    
    def __init__(self, vocab_size: int, hidden_dim: int = 512):
        super().__init__()
        
        self.embedding = nn.Embedding(vocab_size, hidden_dim)
        self.lstm = nn.LSTM(hidden_dim, hidden_dim, num_layers=2, batch_first=True)
        self.policy_head = nn.Linear(hidden_dim, vocab_size)
        self.value_head = nn.Linear(hidden_dim, 1)
    
    def forward(self, x):
        """Forward pass"""
        embedded = self.embedding(x)
        lstm_out, _ = self.lstm(embedded)
        
        policy_logits = self.policy_head(lstm_out)
        value = self.value_head(lstm_out[:, -1, :])
        
        return policy_logits, value
    
    def select_action(self, state):
        """Select action using policy"""
        policy_logits, value = self.forward(state)
        probs = torch.softmax(policy_logits[:, -1, :], dim=-1)
        
        dist = Categorical(probs)
        action = dist.sample()
        
        return action, dist.log_prob(action), value


class CodeRefactoringRL:
    """Train RL agent to refactor code"""
    
    def __init__(self, agent: CodeRLAgent):
        self.agent = agent
        self.optimizer = torch.optim.Adam(agent.parameters(), lr=3e-4)
    
    def train_episode(self, initial_code: str, max_steps: int = 50):
        """Train one episode"""
        state = self._code_to_state(initial_code)
        
        log_probs = []
        values = []
        rewards = []
        
        for step in range(max_steps):
            # Select refactoring action
            action, log_prob, value = self.agent.select_action(state)
            
            # Apply action
            next_code = self._apply_action(state, action)
            
            # Compute reward
            reward = self._compute_reward(next_code)
            
            log_probs.append(log_prob)
            values.append(value)
            rewards.append(reward)
            
            state = self._code_to_state(next_code)
        
        # Compute returns and advantages
        returns = self._compute_returns(rewards)
        advantages = returns - torch.cat(values).squeeze()
        
        # Policy loss
        policy_loss = -(torch.stack(log_probs) * advantages.detach()).mean()
        
        # Value loss
        value_loss = advantages.pow(2).mean()
        
        # Total loss
        loss = policy_loss + 0.5 * value_loss
        
        # Update
        self.optimizer.zero_grad()
        loss.backward()
        self.optimizer.step()
        
        return loss.item()
    
    def _code_to_state(self, code: str) -> torch.Tensor:
        """Convert code to state representation"""
        # Tokenize code
        tokens = self._tokenize(code)
        return torch.tensor([tokens])
    
    def _tokenize(self, code: str) -> List[int]:
        """Tokenize code"""
        # Simplified tokenization
        return [ord(c) % 256 for c in code[:100]]
    
    def _apply_action(self, state: torch.Tensor, action: torch.Tensor) -> str:
        """Apply refactoring action"""
        # Convert action to refactoring operation
        return ""  # Placeholder
    
    def _compute_reward(self, code: str) -> float:
        """Compute reward for code"""
        # Reward based on quality metrics
        return 0.0  # Placeholder
    
    def _compute_returns(self, rewards: List[float], gamma: float = 0.99) -> torch.Tensor:
        """Compute discounted returns"""
        returns = []
        R = 0
        
        for r in reversed(rewards):
            R = r + gamma * R
            returns.insert(0, R)
        
        return torch.tensor(returns)
